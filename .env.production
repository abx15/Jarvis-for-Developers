# Production Environment Configuration Template
# DO NOT COMMIT ACTUAL SECRETS

ENVIRONMENT=production
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@db.jarvis.ai:5432/jarvis_prod

# Redis
REDIS_HOST=redis-master.infra.svc.cluster.local
REDIS_PORT=6379

# Service Discovery
GATEWAY_URL=http://api-gateway
AGENT_SERVICE_URL=http://agent-service:8001
REPO_SERVICE_URL=http://repo-service:8002
BUG_SERVICE_URL=http://bug-service:8003
DEVOPS_SERVICE_URL=http://devops-service:8004
BILLING_SERVICE_URL=http://billing-service:8005

# Auth
JWT_SECRET=your-production-secret-replace-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Third Party
STRIPE_API_KEY=sk_prod_...
GITHUB_CLIENT_ID=...
GITHUB_CLIENT_SECRET=...
OPENAI_API_KEY=sk-proj-...
